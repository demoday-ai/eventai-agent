# === REQUIRED ===
BOT_TOKEN=                              # Telegram bot token from @BotFather
OPENROUTER_API_KEY=                     # OpenRouter API key (sk-or-...)

# === OPTIONAL (defaults work for standalone demo) ===
BOT_MODE=polling
LLM_MODEL=deepseek/deepseek-v3.2
EMBEDDING_MODEL=google/gemini-embedding-001
ORGANIZER_CHAT_ID=0                     # Telegram group ID for support forwarding

# === GITHUB (optional, for repo analysis) ===
GITHUB_TOKEN=

# === INFRASTRUCTURE (defaults work with docker compose) ===
DATABASE_URL=postgresql+asyncpg://eventai:eventai@postgres:5432/eventai
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=changeme
POSTGRES_PASSWORD=eventai

# === LLM PLATFORM MODE (integration with llm-agent-platform) ===
# When MASTER_TOKEN is set, bot registers with platform instead of using OpenRouter directly.
# All LLM calls go through platform: metrics (Prometheus), tracing (Langfuse), circuit breaker.
PLATFORM_URL=http://app:8000            # llm-agent-platform service name in docker network
MASTER_TOKEN=                           # same as MASTER_TOKEN in llm-agent-platform .env
# OPENROUTER_API_KEY not needed - platform has its own key

# === STANDALONE MODE (without llm-agent-platform) ===
# Uncomment OPENROUTER_API_KEY and remove MASTER_TOKEN to use OpenRouter directly:
# OPENROUTER_API_KEY=sk-or-...
# No metrics, no tracing, no circuit breaker in standalone mode
